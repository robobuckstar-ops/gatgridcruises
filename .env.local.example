# ============================================
# GatGridCruises.com — Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to source control.

# --- Supabase (Required for production) ---
# Get these from: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# --- Email (Required for newsletter) ---
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_abc123...

# --- Brevo (Optional — contact list management) ---
# Get from: https://app.brevo.com/settings/keys/api
# If set, new subscribers are added to Brevo as contacts.
BREVO_API_KEY=
# Optional: Brevo list ID to add contacts to (leave blank for no list)
BREVO_LIST_ID=

# --- Affiliate IDs (Required for monetization) ---
# Skyscanner: https://partners.skyscanner.net
SKYSCANNER_API_KEY=
# Booking.com: https://www.booking.com/affiliate-program
BOOKING_AFFILIATE_ID=
# Expedia: https://www.expediapartnersolutions.com
EXPEDIA_AFFILIATE_ID=

# --- Advertising ---
# Google AdSense: https://www.google.com/adsense
GOOGLE_ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXX

# --- Analytics ---
# Google Analytics 4 Measurement ID: https://analytics.google.com → Admin → Data Streams
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# --- Site Config ---
NEXT_PUBLIC_SITE_URL=https://gatgridcruises.com
ADMIN_ALLOWED_EMAILS=robobuckstar@gmail.com

# --- Cron Jobs (Vercel) ---
# Generate a random secret: openssl rand -hex 32
CRON_SECRET=

# --- Concierge Inquiry Form ---
# Make.com webhook URL that receives /concierge form submissions.
# Server-side proxy at /api/concierge applies rate limiting, honeypot check,
# and input sanitization before forwarding here.
CONCIERGE_WEBHOOK_URL=

# --- Client Portal (/my-trip) ---
# Airtable base/table IDs are hardcoded in src/app/api/portal/login/route.ts.
# AIRTABLE_API_KEY: personal access token with read scope on the bookings + clients tables.
#   Get from: https://airtable.com/create/tokens
# PORTAL_JWT_SECRET: signs portal session cookies (HMAC-SHA256, 7-day TTL).
#   Generate: openssl rand -base64 32
AIRTABLE_API_KEY=
PORTAL_JWT_SECRET=
